# Task 3 - Password Generator

import random
import string

print("============================")
print("     Password Generator     ")
print("============================")

while True:

    print("\nWhat do you want to do?")
    print("1. Generate a password")
    print("2. Exit")

    choice = input("\nYour choice: ")

    if choice == '2':
        print("\nOkay bye!")
        break

    if choice != '1':
        print("Please enter 1 or 2 only!")
        continue

    # ask the user how long they want the password
    try:
        length = int(input("\nHow long do you want the password to be? (between 6 and 50): "))
        if length < 6 or length > 50:
            print("Please keep it between 6 and 50!")
            continue
    except ValueError:
        print("That's not a number, try again!")
        continue

    # ask what kind of characters to include
    print("\nWhat should the password include?")

    ans1 = input("Uppercase letters? (yes/no): ").lower()
    ans2 = input("Numbers? (yes/no): ").lower()
    ans3 = input("Symbols? (yes/no): ").lower()

    # start building the character pool
    chars = string.ascii_lowercase  # always add lowercase by default

    if ans1 == 'yes':
        chars += string.ascii_uppercase
    if ans2 == 'yes':
        chars += string.digits
    if ans3 == 'yes':
        chars += string.punctuation

    # now randomly pick characters from the pool
    password = ''
    for i in range(length):
        password += random.choice(chars)

    print("\n------------------------------")
    print("Your generated password is:")
    print(f"  {password}")
    print(f"Length: {len(password)} characters")
    print("------------------------------")

    again = input("\nWant to generate another one? (yes/no): ").lower()
    if again != 'yes':
        print("\nOkay, goodbye!")
        break

